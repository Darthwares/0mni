# SpacetimeDB Configuration
NEXT_PUBLIC_SPACETIMEDB_URI=https://maincloud.spacetimedb.com
NEXT_PUBLIC_SPACETIMEDB_NAME=omni-platform

# SpacetimeAuth OIDC (redirect URIs are computed dynamically from the current origin)
NEXT_PUBLIC_OIDC_AUTHORITY=https://auth.spacetimedb.com/oidc
NEXT_PUBLIC_OIDC_CLIENT_ID=your_client_id_here
